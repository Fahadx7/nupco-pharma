# والإعدادات تُحفظ في config.json تلقائياً

# اسم الصيدلية
PHARMACY_NAME=صيدليتي

# توكن بوت تليجرام (من @BotFather)
BOT_TOKEN=ضع_هنا_توكن_البوت

# Chat ID الخاص بك (من @userinfobot)
MY_CHAT_ID=ضع_هنا_chat_id

# مفتاح Groq AI (من console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
