  "pkg": {
    "assets": [
      "src/**/*",
      "public/**/*"
    ],
    "scripts": []
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "express": "^5.2.1",
    "groq-sdk": "^1.1.2",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "pdf-parse": "^1.1.4"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
