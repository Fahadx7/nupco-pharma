{
  "name": "nupco-tracker",
  "version": "3.0.0",
  "description": "بوت تليجرام لتتبع انتهاء صلاحية أدوية نوبكو — نسخة محلية",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "build": "pkg index.js --targets node18-win-x64 --output dist/nupco-setup.exe --compress GZip"
  },
  "keywords": [
    "telegram",
    "bot",
    "nupco",
    "pharmacy",
    "expiry"
  ],
  "author": "Fahad",
