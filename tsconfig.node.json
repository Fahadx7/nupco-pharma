{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "useDefineForClassFields": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "outDir": "out",
    "baseUrl": ".",
    "paths": { "@/*": ["electron/*"] }
  },
  "include": ["electron/**/*", "sql/**/*"]
}
